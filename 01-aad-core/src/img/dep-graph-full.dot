digraph AAD_Dependencies {
  rankdir=TB;
  compound=true;
  concentrate=true;
  splines=ortho;
  ranksep=0.5;
  nodesep=0.2;
  node [shape=box fontsize=8 fontname="Helvetica" height=0.3 margin="0.06,0.04"];
  edge [color="#999999" arrowsize=0.5];

  subgraph cluster_I {
    label="Section I";
    color="#4a86c8";
    fontcolor="#4a86c8";
    bgcolor="#eef3fa";
    fontsize=11;
    style=rounded;
    penwidth=1.5;

    "agent-environment" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Agent Environment"];
    "observation-function" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Observation\nFunction"];
    "action-transition" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Action Transition"];
    "scope-condition" [style=filled fillcolor="#d8dcdc" color="#7f8c8d" penwidth=2.0 peripheries=2 label="SCOPE: Scope Condition"];
    "composition-consistency" [style=filled fillcolor="#ddc6e6" color="#8e44ad" penwidth=1.0 label="POS: Composition\nConsistency"];
    "causal-structure" [style=filled fillcolor="#ddc6e6" color="#8e44ad" penwidth=1.0 label="POS: Causal Structure"];
    "pearl-causal-hierarchy" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Pearl Causal\nHierarchy"];
    "chronica" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Chronica"];
    "agent-model" [style=filled fillcolor="#bdd4e3" color="#2471a3" penwidth=1.0 label="FORM: Agent Model"];
    "information-bottleneck" [style=filled fillcolor="#bdd4e3" color="#2471a3" penwidth=1.0 label="FORM: Information\nBottleneck"];
    "model-sufficiency" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Model Sufficiency"];
    "model-class-fitness" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Model Class\nFitness"];
    "event-driven-dynamics" [style=filled fillcolor="#bdd4e3" color="#2471a3" penwidth=1.0 label="FORM: Event Driven\nDynamics"];
    "recursive-update" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=2.0 peripheries=2 label="DER: Recursive Update"];
    "action-selection" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=1.0 label="DER: Action Selection"];
    "mismatch-signal" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Mismatch Signal"];
    "mismatch-decomposition" [style=filled fillcolor="#bbdac8" color="#1e8449" penwidth=2.0 peripheries=2 label="RES: Mismatch\nDecomposition"];
    "update-gain" [style=filled fillcolor="#f7c9c4" color="#e74c3c" penwidth=2.0 peripheries=2 label="EMP: Update Gain"];
    "causal-information-yield" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Causal\nInformation Yield"];
    "adaptive-tempo" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=2.0 peripheries=2 label="DEF: Adaptive Tempo"];
    "mismatch-dynamics" [style=filled fillcolor="#f7d8bc" color="#e67e22" penwidth=1.0 label="HYP: Mismatch Dynamics"];
    "deliberation-cost" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=2.0 peripheries=2 label="DER: Deliberation Cost"];
    "gain-sector-bridge" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=2.0 peripheries=2 label="DER: Gain Sector\nBridge"];
    "sector-condition-stability" [style=filled fillcolor="#bbdac8" color="#1e8449" penwidth=2.0 peripheries=2 label="RES: Sector Condition\nStability"];
    "persistence-condition" [style=filled fillcolor="#bbdac8" color="#1e8449" penwidth=2.0 peripheries=2 label="RES: Persistence\nCondition"];
    "structural-adaptation-necessity" [style=filled fillcolor="#bbdac8" color="#1e8449" penwidth=2.0 peripheries=2 label="RES: Structural\nAdaptation Necessity"];
    "temporal-nesting" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=1.0 label="DER: Temporal Nesting"];
    "agent-identity" [style=filled fillcolor="#f2e6b6" color="#d4ac0d" penwidth=1.0 label="DSC: Agent Identity"];
  }

  subgraph cluster_II {
    label="Section II";
    color="#e07b39";
    fontcolor="#e07b39";
    bgcolor="#fdf3ec";
    fontsize=11;
    style=rounded;
    penwidth=1.5;

    "agent-spectrum" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Agent Spectrum"];
    "complete-agent-state" [style=filled fillcolor="#bdd4e3" color="#2471a3" penwidth=2.0 peripheries=2 label="FORM: Complete Agent\nState"];
    "directed-separation" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=1.0 label="DER: Directed\nSeparation"];
    "objective-functional" [style=filled fillcolor="#bdd4e3" color="#2471a3" penwidth=1.0 label="FORM: Objective\nFunctional"];
    "value-object" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Value Object"];
    "strategy-dimension" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Strategy\nDimension"];
    "causal-hierarchy-requirement" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=1.0 label="DER: Causal Hierarchy\nRequirement"];
    "loop-interventional-access" [style=filled fillcolor="#bee6cf" color="#449e6a" penwidth=1.0 label="DER: Loop\nInterventional Access"];
    "ciy-observational-proxy" [style=filled fillcolor="#d8dcdc" color="#7f8888" penwidth=1.0 label="SCOPE: Ciy\nObservational Proxy"];
    "ciy-unified-objective" [style=filled fillcolor="#f2e6b6" color="#b89d33" penwidth=1.0 label="DSC: Ciy Unified\nObjective"];
    "explicit-strategy-condition" [style=filled fillcolor="#ecc3bf" color="#aa5047" penwidth=1.0 label="NORM: Explicit\nStrategy Condition"];
    "chain-confidence-decay" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=2.0 peripheries=2 label="DER: Chain Confidence\nDecay"];
    "and-or-scope" [style=filled fillcolor="#d8dcdc" color="#7f8888" penwidth=1.0 label="SCOPE: And Or Scope"];
    "strategy-dag" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=1.0 label="DEF: Strategy Dag"];
    "satisfaction-gap" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=2.0 peripheries=2 label="DEF: Satisfaction Gap"];
    "control-regret" [style=filled fillcolor="#bed8ea" color="#2980b9" penwidth=2.0 peripheries=2 label="DEF: Control Regret"];
    "strategic-calibration" [style=filled fillcolor="#bed8ea" color="#4680a6" penwidth=1.0 label="DEF: Strategic\nCalibration"];
    "orient-cascade" [style=filled fillcolor="#bee6cf" color="#27ae60" penwidth=1.0 label="DER: Orient Cascade"];
    "observability-dominance" [style=filled fillcolor="#bee6cf" color="#449e6a" penwidth=1.0 label="DER: Observability\nDominance"];
    "edge-update-via-gain" [style=filled fillcolor="#f7d8bc" color="#c47e41" penwidth=1.0 label="HYP: Edge Update Via\nGain"];
    "edge-update-causal-validity" [style=filled fillcolor="#d8dcdc" color="#7f8c8d" penwidth=1.0 label="SCOPE: Edge Update\nCausal Validity"];
    "credit-assignment-boundary" [style=filled fillcolor="#f2e6b6" color="#b89d33" penwidth=1.0 label="DSC: Credit Assignment\nBoundary"];
    "structural-change-as-parametric-limit" [style=filled fillcolor="#bdd4e3" color="#427697" penwidth=1.0 label="FORM: Structural\nChange As Parametric\nLimit"];
    "strategic-tempo" [style=filled fillcolor="#bed8ea" color="#4680a6" penwidth=1.0 label="DEF: Strategic Tempo"];
    "strategy-complexity-cost" [style=filled fillcolor="#bdd4e3" color="#427697" penwidth=1.0 label="FORM: Strategy\nComplexity Cost"];
    "strategy-persistence-schema" [style=filled fillcolor="#f7d8bc" color="#c47e41" penwidth=1.0 label="SCHMA: Strategy\nPersistence Schema"];
    "causal-insufficiency-detection" [style=filled fillcolor="#bee6cf" color="#449e6a" penwidth=1.0 label="DER: Causal\nInsufficiency\nDetection"];
    "exploit-explore-deliberate" [style=filled fillcolor="#f2e6b6" color="#b89d33" penwidth=1.0 label="DSC: Exploit Explore\nDeliberate"];
  }

  subgraph cluster_III {
    label="Section III";
    color="#6b9e3c";
    fontcolor="#6b9e3c";
    bgcolor="#f0f5eb";
    fontsize=11;
    style=rounded;
    penwidth=1.5;

