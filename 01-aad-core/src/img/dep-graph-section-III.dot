digraph AAD_Dependencies {
  rankdir=TB;
  compound=true;
  concentrate=true;
  splines=ortho;
  ranksep=0.5;
  nodesep=0.2;
  node [shape=box fontsize=8 fontname="Helvetica" height=0.3 margin="0.06,0.04"];
  edge [color="#999999" arrowsize=0.5];

  subgraph cluster_III {
    label="Section III";
    color="#6b9e3c";
    fontcolor="#6b9e3c";
    bgcolor="#f0f5eb";
    fontsize=11;
    style=rounded;
    penwidth=1.5;

    "multi-agent-scope" [style=filled fillcolor="#d8dcdc" color="#7f8888" penwidth=1.0 label="SCOPE: Multi Agent\nScope ↑"];
    "composition-closure" [style=filled fillcolor="#bdd4e3" color="#427697" penwidth=1.0 label="FORM: Composition\nClosure ↑"];
    "tempo-composition" [style=filled fillcolor="#dfe4e4" color="#8e9899" penwidth=1.0 label="SKTCH: Tempo\nComposition ↑"];
    "directed-separation-under-composition" [style=filled fillcolor="#f7d8bc" color="#c47e41" penwidth=1.0 label="HYP: Directed\nSeparation Under\nComposition ↑"];
    "unity-dimensions" [style=filled fillcolor="#f2e6b6" color="#b89d33" penwidth=1.0 label="DSC: Unity Dimensions ↑"];
    "shared-intent" [style=filled fillcolor="#bed8ea" color="#4680a6" penwidth=1.0 label="DEF: Shared Intent ↑"];
    "auftragstaktik-principle" [style=filled fillcolor="#f7d8bc" color="#c47e41" penwidth=1.0 label="HYP: Auftragstaktik\nPrinciple ↑"];
    "communication-gain" [style=filled fillcolor="#f7d8bc" color="#c47e41" penwidth=1.0 label="HYP: Communication\nGain ↑"];
    "team-persistence" [style=filled fillcolor="#bee6cf" color="#449e6a" penwidth=1.0 label="DER: Team Persistence ↑"];
    "adversarial-destabilization" [style=filled fillcolor="#bee6cf" color="#449e6a" penwidth=1.0 label="DER: Adversarial\nDestabilization ↑"];
    "adversarial-tempo-advantage" [style=filled fillcolor="#bbdac8" color="#3e825b" penwidth=1.0 label="RES: Adversarial Tempo\nAdvantage ↑"];
    "adversarial-exponent-regimes" [style=filled fillcolor="#bbdac8" color="#3e825b" penwidth=1.0 label="RES: Adversarial\nExponent Regimes ↑"];
    "observation-gates-advantage" [style=filled fillcolor="#f7c9c4" color="#c45d52" penwidth=1.0 label="OBS: Observation Gates\nAdvantage ↑"];
    "per-dimension-persistence" [style=filled fillcolor="#bbdac8" color="#3e825b" penwidth=1.0 label="RES: Per Dimension\nPersistence ↑"];
  }

  "multi-agent-scope" -> "unity-dimensions" [color="#6b9e3c"];
  "composition-closure" -> "unity-dimensions" [color="#6b9e3c"];
  "adversarial-destabilization" -> "adversarial-exponent-regimes" [color="#6b9e3c"];
  "adversarial-tempo-advantage" -> "adversarial-exponent-regimes" [color="#6b9e3c"];
  "multi-agent-scope" -> "directed-separation-under-composition" [color="#6b9e3c"];
  "composition-closure" -> "directed-separation-under-composition" [color="#6b9e3c"];
  "multi-agent-scope" -> "communication-gain" [color="#6b9e3c"];
  "adversarial-destabilization" -> "observation-gates-advantage" [color="#6b9e3c"];
  "multi-agent-scope" -> "composition-closure" [color="#6b9e3c"];
  "composition-closure" -> "tempo-composition" [color="#6b9e3c"];
  "unity-dimensions" -> "shared-intent" [color="#6b9e3c"];
  "communication-gain" -> "team-persistence" [color="#6b9e3c"];
  "adversarial-destabilization" -> "adversarial-tempo-advantage" [color="#6b9e3c"];
  "shared-intent" -> "auftragstaktik-principle" [color="#6b9e3c"];
  "unity-dimensions" -> "auftragstaktik-principle" [color="#6b9e3c"];
}
