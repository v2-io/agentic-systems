#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/extract-known-issues
#
# Composes doc/readme/src/_known-issues.md from three sources, each
# reflecting a different facet of "what the framework currently
# acknowledges as open":
#
#   1. Known Fragilities — structural-scope notes that name what
#      classes of agents fall outside the framework's formal scope.
#      Lives in CLAUDE.md as a `### Known Fragilities`
#      section. Pulled verbatim.
#
#   2. PROPOSALS portfolio — entry titles from §B (Ready now), §C
#      (Soon), §D (Later). Title only, no body — body content would
#      cross the orientation/priming line. The portfolio's existence
#      is itself the signal: the framework knows about these.
#
#   3. OUTLINE GAPs — `--GAP--` rows across each component's
#      OUTLINE.md. These are explicit named gaps in the theory's
#      coverage at the row level — the most honest "the framework
#      knows it has not finished this" surface there is.
#
# Usage:
#   bin/extract-known-issues               # write to disk
#   bin/extract-known-issues --stdout      # write to stdout
#
# Source files:
#   - CLAUDE.md (Known Fragilities; relocated here from CLAUDE-2.md
#     when CLAUDE-2 was sunset 2026-04-28)
#   - PROPOSALS.md (§B, §C, §D)
#   - 01-aad-core/OUTLINE.md, 02-tst-core/OUTLINE.md,
#     03-logogenic-agents/OUTLINE.md, 04-logozoetic-agents/OUTLINE.md

require 'pathname'
require 'optparse'

REPO_ROOT = Pathname.new(__dir__).parent.expand_path
OUTPUT = REPO_ROOT.join('doc/readme/src/_known-issues.md')

KNOWN_FRAGILITIES_SOURCES = [
  REPO_ROOT.join('CLAUDE.md')
].freeze

PROPOSALS = REPO_ROOT.join('PROPOSALS.md')

OUTLINE_FILES = [
  REPO_ROOT.join('01-aad-core/OUTLINE.md'),
  REPO_ROOT.join('02-tst-core/OUTLINE.md'),
  REPO_ROOT.join('03-logogenic-agents/OUTLINE.md'),
  REPO_ROOT.join('04-logozoetic-agents/OUTLINE.md')
].freeze

# --- Known Fragilities ---------------------------------------------------

# Reads the first file containing a `### Known Fragilities` heading.
# Returns the bullet list contents as an array of strings, or [] if not found.
def read_known_fragilities
  KNOWN_FRAGILITIES_SOURCES.each do |path|
    next unless path.exist?
    content = path.read
    next unless content =~ /^###\s+Known Fragilities\b/
    section = content.split(/^###\s+Known Fragilities\b[^\n]*\n/, 2)[1]
    next unless section
    # Stop at the next H1/H2/H3 heading or horizontal rule.
    # Built via Regexp.new with a single-quoted source so the {1,3}
    # quantifier isn't read as Ruby string interpolation.
    stop_re = Regexp.new('^(?:#{1,3}\s|\s*---\s*$)')
    body = section.split(stop_re, 2).first || ''
    bullets = body.lines.select { |l| l.start_with?('- ') }.map { |l| l.sub(/\A-\s+/, '').strip }
    return { source: path.relative_path_from(REPO_ROOT).to_s, items: bullets } if bullets.any?
  end
  { source: nil, items: [] }
end

# --- PROPOSALS B/C/D -----------------------------------------------------

# For each of §B, §C, §D, returns the H3 entry titles within that section.
# Skips H3s under "Cross-cutting view" or "§A Absorbed" by anchoring on
# the H2 markers explicitly.
def read_proposal_titles
  raise "PROPOSALS missing: #{PROPOSALS}" unless PROPOSALS.exist?
  sections = { 'B' => [], 'C' => [], 'D' => [] }
  current = nil
  PROPOSALS.each_line do |line|
    if (m = line.match(/\A##\s+§([A-G])\.\s+/))
      current = sections.key?(m[1]) ? m[1] : nil
    elsif current && (m = line.match(/\A###\s+(.+?)\s*\z/))
      sections[current] << m[1]
    end
  end
  sections
end

# --- OUTLINE GAPs --------------------------------------------------------

# Returns [{component, gap_text}] for every `--GAP--` row in any
# OUTLINE.md. Tolerates leading/trailing whitespace and varying
# table-cell alignment.
def read_outline_gaps
  results = []
  OUTLINE_FILES.each do |path|
    next unless path.exist?
    component = path.dirname.basename.to_s
    path.each_line do |line|
      next unless line.include?('--GAP--')
      cells = line.split('|').map(&:strip)
      next if cells.empty?
      # The gap text is the "Claim" cell in the standard table layout
      # (see FORMAT.md OUTLINE schema). The cell with the descriptive
      # text is consistently the longest non-empty cell after the
      # --GAP-- marker; we extract that rather than rely on cell index,
      # since some component outlines have slight column variations.
      claim = cells.reject { |c| c.empty? || c == '--GAP--' }.max_by(&:length)
      next unless claim
      results << { component: component, text: claim }
    end
  end
  results
end

# --- Assemble output -----------------------------------------------------

options = { stdout: false }
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/extract-known-issues [--stdout]'
  opts.on('--stdout', 'Write to stdout instead of disk') { options[:stdout] = true }
end.parse!

frag = read_known_fragilities
proposals = read_proposal_titles
gaps = read_outline_gaps

output = +<<~HEADER
  <!-- AUTO-GENERATED by bin/extract-known-issues; do not hand-edit. -->
  <!-- Rolls up Known Fragilities, PROPOSALS portfolio (§B/§C/§D titles), and OUTLINE GAPs. -->

  ## Known Issues & Open Questions

  This section surfaces what the framework currently acknowledges as open at the orientation level. For active work items see [`TODO.md`](TODO.md); for architectural proposals under review see [`PROPOSALS.md`](PROPOSALS.md); for component-level GAPs see each component's `OUTLINE.md`.

HEADER

# Section: Known Fragilities
output << "### Known Fragilities — what falls outside formal scope\n\n"
if frag[:items].empty?
  output << "*(No Known Fragilities section found in CLAUDE.md.)*\n\n"
else
  frag[:items].each { |item| output << "- #{item}\n" }
  output << "\n*Source: [`#{frag[:source]}`](#{frag[:source]}).*\n\n"
end

# Section: Proposal portfolio
output << "### Architectural proposals under review\n\n"
%w[B C D].each do |band|
  band_titles = proposals[band]
  band_label = { 'B' => 'Ready now', 'C' => 'Soon', 'D' => 'Later' }[band]
  next if band_titles.empty?
  output << "**§#{band} — #{band_label}.**\n"
  band_titles.each { |t| output << "- #{t}\n" }
  output << "\n"
end
output << "*Full portfolio with merits, scope, and prior reasoning: [`PROPOSALS.md`](PROPOSALS.md).*\n\n"

# Section: OUTLINE GAPs
output << "### Component-level GAPs\n\n"
if gaps.empty?
  output << "*(No GAP rows found across component OUTLINE files.)*\n\n"
else
  by_component = gaps.group_by { |g| g[:component] }
  by_component.each do |component, items|
    output << "**`#{component}`:**\n"
    items.each { |g| output << "- #{g[:text]}\n" }
    output << "\n"
  end
end

if options[:stdout]
  print output
else
  OUTPUT.write(output)
  total = frag[:items].size + proposals.values.sum(&:size) + gaps.size
  puts "Wrote #{OUTPUT.relative_path_from(REPO_ROOT)} (#{total} items, #{output.bytesize} bytes)"
end
