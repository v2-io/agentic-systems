#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/align-slug
#
# Aligns a segment's slug with its `type:` frontmatter value, under the
# `[type]-[subject-noun]` role-prefix discipline. Thin wrapper around
# bin/rename-slug that computes the correct target slug and invokes the
# mechanical rename only if the current slug is not already aligned.
#
# Algorithm:
#   1. Locate the segment file at {component}/src/{slug}.md. Fail if zero
#      or multiple matches (multi-match would require ambiguity resolution
#      the caller must supply).
#   2. Read the `type:` field from the file's YAML frontmatter.
#   3. Resolve the effective type via an optional type→prefix mapping
#      (e.g., `--map worked-example=example` to shorten long type tokens
#      into compact slug prefixes). Mapping keys and values are both
#      treated as recognizable prefix vocabulary for stripping purposes.
#   4. Strip any known type-prefix from the current slug (longest match
#      wins — `worked-example-foo` strips `worked-example-`, not `worked-`).
#      Known prefixes = FORMAT.md's type vocabulary ∪ mapping.keys ∪
#      mapping.values. This recovers the bare subject-noun whether the
#      current prefix is correct, wrong, or absent.
#   5. Compose target = {effective_type}-{subject_noun}.
#   6. If target == current slug, exit 0 (already aligned). Otherwise,
#      invoke bin/rename-slug {current} {target} with any passthrough flags.
#
# Use cases this covers:
#   - New segment never carried a prefix: add one.
#   - Segment carried a correct prefix already: no-op.
#   - Type in the file changed (definition → scope, etc.): swap the prefix.
#   - Mapping changed (adopting `worked-example → example` project-wide):
#     the previously-correct `worked-example-X` becomes `example-X`.
#   - Subject-noun contains a word that looks like a type but isn't a prefix
#     (e.g., `definition-verbose-example-foo`): longest-match-first correctly
#     strips only the leading prefix.
#
# Usage:
#   bin/align-slug SLUG                         # single segment
#   bin/align-slug --all                        # every segment in every component
#   bin/align-slug --map worked-example=example SLUG
#   bin/align-slug --dry-run SLUG               # passthrough to rename-slug
#   bin/align-slug --confirm-merge SLUG         # passthrough to rename-slug
#
# Output is terse for no-ops ("aligned: SLUG") and delegates to rename-slug's
# own output when a rename is actually performed.

require 'optparse'
require 'pathname'

REPO_ROOT = Pathname.new(__dir__).parent.expand_path.freeze

COMPONENT_SRCS = %w[
  01-aad-core/src
  02-tst-core/src
  03-logogenic-agents/src
  04-logozoetic-agents/src
].map { |p| REPO_ROOT / p }.freeze

RENAME_SLUG = (REPO_ROOT / 'bin' / 'rename-slug').freeze

# FORMAT.md type vocabulary (see the `type` table in FORMAT.md). These are
# the strings that can legitimately appear as a segment's slug prefix, and
# therefore the strings we recognize for stripping.
KNOWN_TYPES = %w[
  postulate
  definition
  scope
  formulation
  derived
  result
  corollary
  hypothesis
  normative
  empirical
  observation
  discussion
  measurement
  proposed-schema
  derivation
  worked-example
  detail
  sketch
  aside
].freeze

# --- Frontmatter parsing -----------------------------------------------

def parse_frontmatter_type(path)
  lines = path.read.each_line.to_a
  return nil unless lines.first&.strip == '---'
  lines[1..].each do |line|
    stripped = line.strip
    break if stripped == '---'
    next unless stripped.start_with?('type:')
    return stripped.split(':', 2)[1].strip
  end
  nil
end

# --- Segment location --------------------------------------------------

def locate_segment(slug)
  matches = COMPONENT_SRCS.map { |d| d / "#{slug}.md" }.select(&:exist?)
  if matches.empty?
    abort("ERROR: no segment file found for slug '#{slug}' in any component src/.")
  end
  if matches.length > 1
    locs = matches.map { |m| "  #{m.relative_path_from(REPO_ROOT)}" }.join("\n")
    abort("ERROR: slug '#{slug}' resolves to multiple files:\n#{locs}")
  end
  matches.first
end

# --- Target-slug computation -------------------------------------------

# Strippable-prefix vocabulary = built-in types plus both sides of any
# user-supplied mapping. Longest-first sort so `worked-example-foo` matches
# `worked-example-` before the shorter `worked-` would (and if some
# contrived mapping introduced `example` as a prefix, the same sort rule
# handles the `example-foo` vs `worked-example-foo` ambiguity correctly).
def strippable_prefixes(mapping)
  (KNOWN_TYPES + mapping.keys + mapping.values).uniq.sort_by { |t| -t.length }
end

def bare_subject(slug, mapping)
  strippable_prefixes(mapping).each do |pre|
    prefix = "#{pre}-"
    return slug[prefix.length..] if slug.start_with?(prefix)
  end
  slug
end

def effective_type(type, mapping)
  mapping.fetch(type, type)
end

def target_slug(current_slug, type, mapping)
  subject = bare_subject(current_slug, mapping)
  "#{effective_type(type, mapping)}-#{subject}"
end

# --- rename-slug invocation --------------------------------------------

def invoke_rename_slug(old_slug, new_slug, passthrough)
  Dir.chdir(REPO_ROOT) do
    system(RENAME_SLUG.to_s, old_slug, new_slug, *passthrough, exception: true)
  end
end

# --- Per-slug workflow -------------------------------------------------

def align_one(slug, mapping, passthrough)
  file = locate_segment(slug)
  type = parse_frontmatter_type(file)
  if type.nil? || type.empty?
    abort("ERROR: #{file.relative_path_from(REPO_ROOT)}: no `type:` frontmatter field.")
  end
  target = target_slug(slug, type, mapping)
  if target == slug
    puts "aligned: #{slug} (type=#{type})"
    return :noop
  end
  puts "renaming: #{slug} → #{target} (type=#{type})"
  invoke_rename_slug(slug, target, passthrough)
  :renamed
end

def every_segment_slug
  COMPONENT_SRCS.flat_map do |dir|
    next [] unless dir.exist?
    dir.glob('*.md').map { |p| p.basename('.md').to_s }
  end.sort
end

# --- CLI ---------------------------------------------------------------

def parse_args
  options = { mapping: {}, passthrough: [], all: false }
  parser = OptionParser.new do |o|
    o.banner = 'Usage: bin/align-slug [options] SLUG   (or --all)'
    o.on('--map KEY=VAL', 'type→prefix mapping entry (repeatable); e.g. --map worked-example=example') do |pair|
      k, v = pair.split('=', 2)
      abort('ERROR: --map expects KEY=VAL') unless k && v && !k.empty? && !v.empty?
      options[:mapping][k] = v
    end
    o.on('--all', 'align every segment in every component src/') { options[:all] = true }
    o.on('--dry-run', 'passthrough: do not mutate, just show plan') do
      options[:passthrough] << '--dry-run'
    end
    o.on('--confirm-merge', 'passthrough: proceed when NEW slug already has references') do
      options[:passthrough] << '--confirm-merge'
    end
    o.on('--detail', 'passthrough: show per-file edit breakdown') do
      options[:passthrough] << '--detail'
    end
    o.on('-h', '--help', 'show help') { puts o; exit }
  end
  parser.parse!

  if options[:all]
    abort('ERROR: cannot combine --all with a positional SLUG') unless ARGV.empty?
  else
    abort("ERROR: provide a SLUG or --all\n\n#{parser}") unless ARGV.length == 1
  end

  options
end

def main
  options = parse_args
  slugs = options[:all] ? every_segment_slug : [ARGV[0]]

  counts = Hash.new(0)
  slugs.each do |slug|
    result = align_one(slug, options[:mapping], options[:passthrough])
    counts[result] += 1
  rescue SystemExit => e
    # abort() from align_one short-circuits a single slug only when --all;
    # we let it propagate for single-slug mode.
    raise unless options[:all]
    counts[:error] += 1
    warn "  (continuing with remaining slugs)"
  end

  return unless options[:all]
  puts
  puts "── Summary"
  puts "  aligned (no-op): #{counts[:noop]}"
  puts "  renamed:         #{counts[:renamed]}"
  puts "  errors:          #{counts[:error]}" if counts[:error].positive?
end

main if $PROGRAM_NAME == __FILE__
