#!/usr/bin/env python3
"""
Lint an outline file against segment frontmatter dependencies.

Checks:
  1. Ordering violations: segment listed before a dependency in the outline
  2. Missing dependencies: segment depends on a slug that doesn't exist as a file
  3. Undeclared dependencies: segment references #slug in body but slug not in depends
  4. Orphan segments: files in src/ not referenced in the outline

Usage:
    bin/lint-outline [options] [OUTLINE_FILE]

    OUTLINE_FILE defaults to 01-aad-core/OUTLINE.md

Options:
    --graph FILE    Write a Graphviz DOT file of the dependency graph
    --section S     Only check/graph a specific section (I, II, III, A, B)
    --svg FILE      Write SVG directly (requires dot command)
    --diagrams      Generate all dependency diagrams into src/img/
    --quiet         Only show violations, not summary
    --help          Show this help

Exit code 0 = clean, 1 = violations found.
"""

import os
import re
import sys
import subprocess
from pathlib import Path
from collections import defaultdict

# ── Frontmatter parsing ────────────────────────────────────────────

def parse_frontmatter(filepath):
    """Extract slug, depends, and stage from YAML frontmatter."""
    result = {"slug": None, "depends": [], "stage": None, "type": None, "status": None}
    try:
        with open(filepath, "r") as f:
            lines = f.readlines()
    except (OSError, UnicodeDecodeError):
        return result

    if not lines or lines[0].strip() != "---":
        return result

    in_depends = False
    for line in lines[1:]:
        stripped = line.strip()
        if stripped == "---":
            break
        if stripped.startswith("slug:"):
            result["slug"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("stage:"):
            result["stage"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("type:"):
            result["type"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("status:"):
            result["status"] = stripped.split(":", 1)[1].strip()
        elif stripped.startswith("depends:"):
            rest = stripped.split(":", 1)[1].strip()
            if rest:
                # Inline list: depends: [a, b, c] or depends: a
                rest = rest.strip("[]")
                result["depends"] = [d.strip().strip("'\"") for d in rest.split(",") if d.strip()]
            else:
                in_depends = True
        elif in_depends:
            if stripped.startswith("- "):
                result["depends"].append(stripped[2:].strip().strip("'\""))
            else:
                in_depends = False

    return result


# ── Outline parsing ────────────────────────────────────────────────

def parse_outline(outline_path):
    """
    Parse an OUTLINE.md file.
    Returns a list of (section, slug, row_index) in order of appearance.
    Also returns section metadata (preamble text etc).
    """
    entries = []
    current_section = None
    row_index = 0

    with open(outline_path, "r") as f:
        for line in f:
            # Detect section headers
            m = re.match(r'^##\s+(I+|III|IV|V|A|B)\.\s', line)
            if m:
                current_section = m.group(1)
                continue

            # Also detect "## Appendices:" style headers
            if re.match(r'^##\s+Appendices', line):
                current_section = "A"  # default; will be overridden by table content
                continue

            # Parse table rows with slug references
            # Format: | § | Type | N | [#slug](src/slug.md) | Claim | Stage |
            m = re.search(r'\[#([a-zA-Z0-9_-]+)\]\(src/', line)
            if m:
                slug = m.group(1)
                # Try to get section from the first column
                cols = [c.strip() for c in line.split("|")]
                if len(cols) >= 2:
                    sec = cols[1].strip()
                    if sec in ("I", "II", "III", "IV", "V", "A", "B"):
                        current_section = sec

                entries.append((current_section, slug, row_index))
                row_index += 1

    return entries


# ── Violation detection ────────────────────────────────────────────

def find_ordering_violations(entries, all_deps):
    """
    Find cases where a segment appears before one of its dependencies
    in the outline ordering.

    Classifies violations as:
    - "intra-section": both slug and dep are in the same section (true violations)
    - "backmatter": dep is in an appendix section (A, B) and slug is in a main
      section (I, II, III) — intentional presentation order (results before proofs)
    - "cross-section": other cross-section violations
    """
    APPENDIX_SECTIONS = {"A", "B"}
    MAIN_SECTIONS = {"I", "II", "III", "IV", "V"}

    slug_to_index = {}
    slug_to_section = {}
    for section, slug, idx in entries:
        slug_to_index[slug] = idx
        slug_to_section[slug] = section

    violations = []
    for section, slug, idx in entries:
        deps = all_deps.get(slug, [])
        for dep in deps:
            dep_idx = slug_to_index.get(dep)
            if dep_idx is not None and dep_idx > idx:
                dep_section = slug_to_section.get(dep)
                if section == dep_section:
                    kind = "intra-section"
                elif dep_section in APPENDIX_SECTIONS and section in MAIN_SECTIONS:
                    kind = "backmatter"
                elif dep_section in APPENDIX_SECTIONS and section in APPENDIX_SECTIONS:
                    kind = "intra-appendix"
                else:
                    kind = "cross-section"

                violations.append({
                    "slug": slug,
                    "slug_idx": idx,
                    "dep": dep,
                    "dep_idx": dep_idx,
                    "section": section,
                    "dep_section": dep_section,
                    "kind": kind,
                })

    return violations


def find_missing_deps(all_deps, existing_slugs):
    """Find dependencies that reference non-existent slugs."""
    missing = []
    for slug, deps in all_deps.items():
        for dep in deps:
            if dep not in existing_slugs:
                missing.append({"slug": slug, "dep": dep})
    return missing


def find_orphan_segments(src_dir, outline_slugs, all_slugs):
    """Find src/ files not referenced in the outline."""
    orphans = []
    for slug in all_slugs:
        if slug not in outline_slugs and not slug.startswith("old-"):
            orphans.append(slug)
    return orphans


# ── Graphviz output ────────────────────────────────────────────────

SECTION_COLORS = {
    "I": "#4a86c8",
    "II": "#e07b39",
    "III": "#6b9e3c",
    "A": "#888888",
    "B": "#aa7744",
}

SECTION_BG = {
    "I": "#eef3fa",
    "II": "#fdf3ec",
    "III": "#f0f5eb",
    "A": "#f5f5f5",
    "B": "#f8f4ef",
}

TYPE_COLORS = {
    "postulate":        "#8e44ad",  # purple — foundational axioms
    "definition":       "#2980b9",  # blue — what things are
    "formulation":      "#2471a3",  # darker blue — representational choices
    "scope":            "#7f8c8d",  # gray — boundary conditions
    "derived":          "#27ae60",  # green — proved results
    "result":           "#1e8449",  # darker green — major results
    "hypothesis":       "#e67e22",  # orange — conjectured
    "discussion":       "#d4ac0d",  # gold — interpretive
    "empirical":        "#e74c3c",  # red — data-driven
    "normative":        "#c0392b",  # darker red — prescriptive
    "derivation":       "#27ae60",  # green — proof appendix
    "sketch":           "#95a5a6",  # light gray — incomplete
    "detail":           "#95a5a6",  # light gray — supporting
    "worked-example":   "#16a085",  # teal — instantiation
    "proposed-schema":  "#e67e22",  # orange — not yet proved
    "observation":      "#e74c3c",  # red — empirical
    "derived + scope":  "#27ae60",  # green
    "definition + discussion": "#2980b9",  # blue
}

APPENDIX_SECTIONS = {"A", "B"}
MAIN_SECTIONS = {"I", "II", "III", "IV", "V"}


TYPE_PREFIXES = {
    "postulate":        "POS",
    "definition":       "DEF",
    "formulation":      "FORM",
    "scope":            "SCOPE",
    "derived":          "DER",
    "result":           "RES",
    "hypothesis":       "HYP",
    "discussion":       "DSC",
    "empirical":        "EMP",
    "normative":        "NORM",
    "derivation":       "PROOF",
    "sketch":           "SKTCH",
    "detail":           "DTL",
    "worked-example":   "EX",
    "proposed-schema":  "SCHMA",
    "observation":      "OBS",
    "derived + scope":  "DER",
    "definition + discussion": "DEF",
}


def _title_case(slug):
    """Convert a slug to Title Case: 'gain-sector-bridge' → 'Gain Sector Bridge'."""
    return " ".join(word.capitalize() for word in slug.split("-"))


def _short_label(slug, seg_type=None):
    """Make a compact, title-cased label with type prefix from a slug."""
    title = _title_case(slug)

    # Add type prefix
    prefix = ""
    if seg_type:
        seg_type_lower = seg_type.strip().lower()
        prefix = TYPE_PREFIXES.get(seg_type_lower, seg_type_lower[:4].upper())
        prefix = f"{prefix}: "

    full = f"{prefix}{title}"

    # Wrap at ~22 chars per line
    words = full.split(" ")
    lines = []
    current = words[0]
    for w in words[1:]:
        if len(current) + len(w) + 1 > 22:
            lines.append(current)
            current = w
        else:
            current += " " + w
    lines.append(current)
    return "\\n".join(lines)


def write_dot(entries, all_deps, slug_to_section, slug_to_meta, filepath,
              section_filter=None, exclude_sections=None):
    """Write a Graphviz DOT file."""
    exclude_sections = set(exclude_sections or [])

    # Determine which slugs to include
    if section_filter:
        include = {slug for sec, slug, _ in entries if sec == section_filter}
        # Track which nodes have external deps (for marking) but don't show them
        has_external_deps = set()
        for slug in include:
            for dep in all_deps.get(slug, []):
                if dep not in include:
                    has_external_deps.add(slug)
        external = set()  # empty — don't render external nodes in section views
    else:
        include = {slug for sec, slug, _ in entries if sec not in exclude_sections}
        has_external_deps = set()
        external = set()
        for slug in include:
            for dep in all_deps.get(slug, []):
                if dep not in include:
                    external.add(dep)

    # Desired section ordering for vertical layout
    SECTION_ORDER = ["I", "II", "III", "A", "B"]

    with open(filepath, "w") as f:
        f.write("digraph AAD_Dependencies {\n")
        f.write("  rankdir=TB;\n")
        f.write("  compound=true;\n")
        f.write("  concentrate=true;\n")
        f.write("  splines=ortho;\n")
        f.write("  ranksep=0.5;\n")
        f.write("  nodesep=0.2;\n")
        f.write('  node [shape=box fontsize=8 fontname="Helvetica" height=0.3 margin="0.06,0.04"];\n')
        f.write('  edge [color="#999999" arrowsize=0.5];\n\n')

        # Group by section using subgraphs
        sections_seen = {}
        for sec, slug, _ in entries:
            if slug in include:
                if sec not in sections_seen:
                    sections_seen[sec] = []
                sections_seen[sec].append(slug)

        for sec, slugs in sections_seen.items():
            color = SECTION_COLORS.get(sec, "#999999")
            bg = SECTION_BG.get(sec, "#fafafa")
            f.write(f"  subgraph cluster_{sec} {{\n")
            sec_label = {"A": "Appendices: Details", "B": "Appendices: Domains"}.get(sec, f"Section {sec}")
            f.write(f'    label="{sec_label}";\n')
            f.write(f'    color="{color}";\n')
            f.write(f'    fontcolor="{color}";\n')
            f.write(f'    bgcolor="{bg}";\n')
            f.write(f"    fontsize=11;\n")
            f.write(f"    style=rounded;\n")
            f.write(f"    penwidth=1.5;\n\n")

            for slug in slugs:
                meta = slug_to_meta.get(slug, {})
                stage = meta.get("stage", "draft")
                seg_type = (meta.get("type") or "").strip().lower()
                label = _short_label(slug, meta.get("type"))
                # Mark nodes with external dependencies
                if slug in has_external_deps:
                    label += " ↑"

                # Color from type
                fill = TYPE_COLORS.get(seg_type, "#cccccc")
                # Lighten fill, use full color for border
                # Convert hex to lighter version for fill
                r, g, b = int(fill[1:3], 16), int(fill[3:5], 16), int(fill[5:7], 16)
                lr = min(255, r + (255 - r) * 7 // 10)
                lg = min(255, g + (255 - g) * 7 // 10)
                lb = min(255, b + (255 - b) * 7 // 10)
                light_fill = f"#{lr:02x}{lg:02x}{lb:02x}"

                # Double outline for claims-verified
                if stage == "claims-verified":
                    peripheries = "peripheries=2"
                    penwidth = "penwidth=2.0"
                else:
                    peripheries = ""
                    penwidth = "penwidth=1.0"

                # Slightly muted for draft (lower saturation border)
                if stage == "draft":
                    # Desaturate the border color
                    dr = r + (128 - r) // 3
                    dg = g + (128 - g) // 3
                    db = b + (128 - b) // 3
                    border = f"#{dr:02x}{dg:02x}{db:02x}"
                else:
                    border = fill

                attrs = f'style=filled fillcolor="{light_fill}" color="{border}" {penwidth}'
                if peripheries:
                    attrs += f" {peripheries}"
                f.write(f'    "{slug}" [{attrs} label="{label}"];\n')

            f.write("  }\n\n")

        # External nodes
        if external:
            # In per-section views, force external deps to the top rank
            if section_filter:
                f.write("  { rank=source;\n")
                for slug in sorted(external):
                    f.write(f'    "{slug}" [style=dashed color="#cccccc" fontcolor="#999999" label="{_short_label(slug, None)}"];\n')
                f.write("  }\n\n")
            else:
                for slug in external:
                    f.write(f'  "{slug}" [style=dashed color="#cccccc" fontcolor="#999999" label="{_short_label(slug, None)}"];\n')
                f.write("\n")

        # Edges — classify backmatter vs intra-section
        for slug in include:
            slug_sec = slug_to_section.get(slug)
            for dep in all_deps.get(slug, []):
                if dep not in include and dep not in external:
                    continue
                dep_sec = slug_to_section.get(dep)

                # Backmatter edge: main body depends on appendix proof
                if slug_sec in MAIN_SECTIONS and dep_sec in APPENDIX_SECTIONS:
                    f.write(f'  "{dep}" -> "{slug}" [style=dashed color="#cccccc" constraint=false];\n')
                # Cross-section edge between main sections — keep constraint
                # so the dependency flow forces vertical section ordering
                elif slug_sec != dep_sec and slug_sec in MAIN_SECTIONS and dep_sec in MAIN_SECTIONS:
                    f.write(f'  "{dep}" -> "{slug}" [color="#aaaaaa"];\n')
                # Intra-appendix cross-reference
                elif slug_sec in APPENDIX_SECTIONS and dep_sec in APPENDIX_SECTIONS and slug_sec != dep_sec:
                    f.write(f'  "{dep}" -> "{slug}" [color="#bbbbbb"];\n')
                else:
                    # Normal intra-section edge
                    sec_color = SECTION_COLORS.get(slug_sec, "#666666")
                    f.write(f'  "{dep}" -> "{slug}" [color="{sec_color}"];\n')

        f.write("}\n")


# ── Main ───────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]

    # Parse arguments
    graph_file = None
    svg_file = None
    section_filter = None
    diagrams = False
    quiet = False
    outline_file = None

    i = 0
    while i < len(args):
        if args[i] == "--graph":
            i += 1
            graph_file = args[i]
        elif args[i] == "--svg":
            i += 1
            svg_file = args[i]
        elif args[i] == "--section":
            i += 1
            section_filter = args[i]
        elif args[i] == "--diagrams":
            diagrams = True
        elif args[i] == "--quiet":
            quiet = True
        elif args[i] == "--help":
            print(__doc__)
            sys.exit(0)
        elif not args[i].startswith("-"):
            outline_file = args[i]
        i += 1

    # Resolve paths
    script_dir = Path(__file__).resolve().parent
    project_root = script_dir.parent

    if outline_file is None:
        outline_file = project_root / "01-aad-core" / "OUTLINE.md"
    else:
        outline_file = Path(outline_file)

    outline_dir = outline_file.parent
    src_dir = outline_dir / "src"

    if not outline_file.exists():
        print(f"Error: {outline_file} not found", file=sys.stderr)
        sys.exit(1)

    # ── Collect all segment metadata ───────────────────────────────

    all_deps = {}       # slug → [dep_slugs]
    all_slugs = set()   # all slugs found in src/
    slug_to_meta = {}   # slug → {stage, type, status, depends}

    if src_dir.exists():
        for md_file in sorted(src_dir.glob("*.md")):
            meta = parse_frontmatter(md_file)
            slug = meta["slug"] or md_file.stem
            all_slugs.add(slug)
            all_deps[slug] = meta["depends"]
            slug_to_meta[slug] = {
                "stage": meta["stage"],
                "type": meta["type"],
                "status": meta["status"],
                "depends": meta["depends"],
            }

    # ── Parse outline ──────────────────────────────────────────────

    entries = parse_outline(outline_file)
    outline_slugs = {slug for _, slug, _ in entries}

    # Build section map
    slug_to_section = {}
    for sec, slug, _ in entries:
        slug_to_section[slug] = sec

    # ── Check for violations ───────────────────────────────────────

    violations = find_ordering_violations(entries, all_deps)
    missing = find_missing_deps(all_deps, all_slugs)
    orphans = find_orphan_segments(src_dir, outline_slugs, all_slugs)

    # Filter by section if requested
    if section_filter:
        violations = [v for v in violations if v["section"] == section_filter]

    has_issues = False

    # Separate violations by kind
    true_violations = [v for v in violations if v["kind"] in ("intra-section", "intra-appendix", "cross-section")]
    backmatter_refs = [v for v in violations if v["kind"] == "backmatter"]

    if true_violations:
        has_issues = True
        print(f"\n{'='*60}")
        print(f" ORDERING VIOLATIONS ({len(true_violations)})")
        print(f"{'='*60}\n")
        for v in true_violations:
            kind_label = f"[{v['kind']}]"
            print(f"  {v['slug']} (§{v['section']}, row {v['slug_idx']}) depends on {v['dep']} (§{v.get('dep_section','?')}, row {v['dep_idx']})  {kind_label}")
            print(f"    → {v['slug']} must come AFTER {v['dep']}")
            print()

    if backmatter_refs and not quiet:
        print(f"\n{'='*60}")
        print(f" BACKMATTER REFERENCES ({len(backmatter_refs)}) — intentional presentation order")
        print(f"{'='*60}\n")
        for v in backmatter_refs:
            print(f"  {v['slug']} (§{v['section']}) references proof in {v['dep']} (§{v.get('dep_section','?')})")
        print()

    if missing:
        has_issues = True
        print(f"\n{'='*60}")
        print(f" MISSING DEPENDENCIES ({len(missing)})")
        print(f"{'='*60}\n")
        for m in missing:
            print(f"  {m['slug']} depends on {m['dep']} — no such file in src/")

    if orphans and not quiet:
        print(f"\n{'='*60}")
        print(f" ORPHAN SEGMENTS ({len(orphans)})")
        print(f"{'='*60}\n")
        for o in sorted(orphans):
            print(f"  src/{o}.md — not referenced in outline")

    # ── Summary ────────────────────────────────────────────────────

    if not quiet:
        print(f"\n{'='*60}")
        print(f" SUMMARY")
        print(f"{'='*60}\n")
        print(f"  Outline entries:      {len(entries)}")
        print(f"  Segment files:        {len(all_slugs)}")
        print(f"  Ordering violations:  {len(true_violations)}")
        print(f"  Backmatter refs:      {len(backmatter_refs)}")
        print(f"  Missing dependencies: {len(missing)}")
        print(f"  Orphan segments:      {len(orphans)}")

        # Stage distribution
        stages = defaultdict(int)
        for slug in outline_slugs:
            meta = slug_to_meta.get(slug, {})
            stage = meta.get("stage") or "unknown"
            stages[stage] += 1
        print(f"\n  Stage distribution:")
        for stage in ["claims-verified", "deps-verified", "draft", "missing", "unknown"]:
            if stages[stage]:
                print(f"    {stage:20s} {stages[stage]:3d}")

    # ── Graph output ───────────────────────────────────────────────

    if graph_file:
        write_dot(entries, all_deps, slug_to_section, slug_to_meta, graph_file, section_filter)
        if not quiet:
            print(f"\n  Graph written to: {graph_file}")

    if svg_file:
        dot_path = str(Path(svg_file).with_suffix(".dot"))
        write_dot(entries, all_deps, slug_to_section, slug_to_meta, dot_path, section_filter)
        try:
            subprocess.run(["dot", "-Tsvg", "-o", svg_file, dot_path], check=True)
            if not quiet:
                print(f"  SVG written to: {svg_file}")
                print(f"  DOT written to: {dot_path}")
        except FileNotFoundError:
            print("  Warning: 'dot' command not found. Install graphviz for SVG output.", file=sys.stderr)
            print(f"  DOT file written to: {dot_path}")
        except subprocess.CalledProcessError as e:
            print(f"  Warning: dot failed: {e}", file=sys.stderr)

    # ── Diagrams mode ────────────────────────────────────────────────

    if diagrams:
        img_dir = outline_dir / "src" / "img"
        img_dir.mkdir(exist_ok=True)

        # (section_filter, exclude_sections, filename, description)
        diagram_specs = [
            (None, ["B"], "dep-graph-full.svg", "full dependency graph"),
            ("I", None, "dep-graph-section-I.svg", "Section I"),
            ("II", None, "dep-graph-section-II.svg", "Section II"),
            ("III", None, "dep-graph-section-III.svg", "Section III"),
        ]

        for sec, excl, filename, desc in diagram_specs:
            svg_path = img_dir / filename
            dot_path = svg_path.with_suffix(".dot")
            write_dot(entries, all_deps, slug_to_section, slug_to_meta, str(dot_path), sec, excl)
            try:
                subprocess.run(["dot", "-Tsvg", "-o", str(svg_path), str(dot_path)], check=True)
                if not quiet:
                    print(f"  {desc}: {svg_path}")
            except FileNotFoundError:
                print("  Warning: 'dot' not found. Install graphviz.", file=sys.stderr)
                break
            except subprocess.CalledProcessError as e:
                print(f"  Warning: dot failed for {desc}: {e}", file=sys.stderr)

        if not quiet:
            print()

    if not quiet:
        print()

    sys.exit(1 if has_issues else 0)


if __name__ == "__main__":
    main()
